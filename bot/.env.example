APP_ENV=dev
BOT_TOKEN=
ADMIN_CHAT_ID=
ADMIN_IDS=
# Можно не указывать для локальных тестов, тогда будет использовано:
# postgresql://postgres:postgres@127.0.0.1:5432/poizon_bot
DATABASE_URL=
ADMIN_USERNAME=

# Переменные для будущей официальной оплаты.
# Сейчас бот использует заглушку в src/services/payment_service.py,
# но эти значения понадобятся при подключении ЮKassa или другого провайдера.
PAYMENT_PROVIDER=yookassa
PAYMENT_SHOP_ID=
PAYMENT_SECRET_KEY=
PAYMENT_RETURN_URL=https://t.me/your_bot
PAYMENT_WEBHOOK_SECRET=
